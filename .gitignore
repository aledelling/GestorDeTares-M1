```xml
# Generated build files
app/build/
app/src/main/res/generated/

# Gradle
.gradle/
build/
*.gradle

# Local configuration file (sdk path, etc)
local.properties

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild

# Contains various paths for built variants
.path

# If you're using Android NDK
*.so
*.dll
*.a

# IntelliJ IDEA artifacts
*.iml
*.iws
.idea/

# Temporary files
*.tmp
*.temp
*.swp

# Environment files
.env
.env.local
*.env.*

# Coverage reports
coverage/
*.gcov
*.lcov

# MyPy cache
.mypy_cache/
.mypy_cache/*
```