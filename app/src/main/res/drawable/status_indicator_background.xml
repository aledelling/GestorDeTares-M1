<?xml version="1.0" encoding="utf-8"?>
<!--
    Drawable para el indicador visual de estado de la tarea
    
    Este fondo cambia de color según el estado:
    - Verde (task_completed) cuando la tarea está completada
    - Naranja (task_pending) cuando la tarea está pendiente
    
    Diseño minimalista con esquinas redondeadas
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Color de fondo que se actualizará programáticamente -->
    <solid android:color="@color/task_pending" />

    <!-- Esquinas redondeadas para un look moderno y suave -->
    <corners android:radius="4dp" />

</shape>
